# Copy this file to exactly one of the following local files, then fill placeholders:
#   .env.dev   - used only when APP_ENV=dev
#   .env.test  - used only when APP_ENV=test
#   .env.prod  - used only when APP_ENV=prod
#
# APP_ENV is selected by the shell before startup, not by this file:
#   PowerShell: $env:APP_ENV = "dev"
#   POSIX:      export APP_ENV=dev
#
# Do not commit .env, .env.dev, .env.test, .env.prod, or any other .env.* file.

# Development model settings (.env.dev)
DEV_API_BASE_URL=https://api.example.com/v1
DEV_API_KEY=your_dev_api_key_here
DEV_MODEL_NAME=your_dev_model_name_here
DEV_REASONING_API_BASE_URL=https://api.example.com/v1
DEV_REASONING_API_KEY=your_dev_reasoning_api_key_here
DEV_REASONING_MODEL_NAME=your_dev_reasoning_model_name_here

# Test model settings (.env.test). Automated tests use mocks and must not call real LLMs.
TEST_API_BASE_URL=https://api.example.com/v1
TEST_API_KEY=your_test_api_key_here
TEST_MODEL_NAME=your_test_model_name_here
TEST_REASONING_API_BASE_URL=https://api.example.com/v1
TEST_REASONING_API_KEY=your_test_reasoning_api_key_here
TEST_REASONING_MODEL_NAME=your_test_reasoning_model_name_here

# Production model settings (.env.prod). Required before APP_ENV=prod can start.
PROD_API_BASE_URL=https://api.example.com/v1
PROD_API_KEY=your_prod_api_key_here
PROD_MODEL_NAME=your_prod_model_name_here
PROD_REASONING_API_BASE_URL=https://api.example.com/v1
PROD_REASONING_API_KEY=your_prod_reasoning_api_key_here
PROD_REASONING_MODEL_NAME=your_prod_reasoning_model_name_here

# Production MySQL settings (.env.prod). Required by config.prod.yaml.
PROD_MYSQL_HOST=your_prod_mysql_host_here
PROD_MYSQL_PORT=3306
PROD_MYSQL_USER=your_prod_mysql_user_here
PROD_MYSQL_PASSWORD=your_prod_mysql_password_here
PROD_MYSQL_DATABASE=your_prod_mysql_database_here
